# Copy to backend/.env and fill in real values. Never commit .env.
ASTRA_DATABASE_URL=postgresql+asyncpg://astra:change-me@localhost:5432/astra
ASTRA_JWT_SECRET_KEY=generate-a-long-random-string
ASTRA_ENVIRONMENT=development

# Public base URL of this backend, as reached by Windows agents and the portal.
# Baked into every generated agent installer, so it must be publicly resolvable.
# Production: https://api.astra.technomateai.com
ASTRA_PUBLIC_API_URL=http://localhost:8000

# Portal base URL (Stripe redirects back here). Production: https://astra.technomateai.com
ASTRA_PUBLIC_APP_URL=http://localhost:3000

# Browser origins allowed to call this API directly (JSON list).
# Production: ["https://astra.technomateai.com"]
ASTRA_CORS_ORIGINS=["http://localhost:3000"]

# TEMPORARY WORKAROUND ONLY — leave empty when ASTRA_PUBLIC_API_URL is a custom
# domain that resolves publicly. If set, the portable installer pins the API
# hostname to this IP in each endpoint's hosts file. A hosts pin OVERRIDES DNS,
# so a stale one blackholes every agent carrying it once the IP changes.
ASTRA_AGENT_BACKEND_IP=

# AI engine — set this to enable real Claude responses (bills your Anthropic account).
# Leave unset to use the offline deterministic stub. Get a key at https://console.anthropic.com
ASTRA_ANTHROPIC_API_KEY=sk-ant-...

# Agent auto-update channel. The backend only RELAYS the already-signed manifest from these
# URLs — it never signs (releases are signed in CI). Agents verify the signature against a key
# pinned in their binary, so a compromise of this backend cannot forge a fleet update. Point
# these at your GitHub Releases "latest" assets. Both must be set to enable auto-update.
ASTRA_AGENT_UPDATE_MANIFEST_URL=
ASTRA_AGENT_UPDATE_SIGNATURE_URL=
# Example (replace OWNER/REPO):
#   ASTRA_AGENT_UPDATE_MANIFEST_URL=https://github.com/OWNER/REPO/releases/latest/download/manifest.json
#   ASTRA_AGENT_UPDATE_SIGNATURE_URL=https://github.com/OWNER/REPO/releases/latest/download/manifest.json.sig
